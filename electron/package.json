{
  "name": "ai-presentation-coach-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop shell for AI Presentation Coach (Electron + bundled Flask backend + Next.js standalone)",
  "author": "AI Presentation Coach",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env ELECTRON_DEV=1 electron .",
    "pack": "electron-builder --dir",
    "predist": "node ./node_modules/electron/install.js",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.aipresentationcoach.app",
    "productName": "AI Presentation Coach",
    "electronDist": "node_modules/electron/dist",
    "compression": "normal",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend.exe",
        "to": "backend.exe"
      },
      {
        "from": "resources/frontend",
        "to": "frontend"
      }
    ],
    "win": {
      "sign": null,
      "verifyUpdateCodeSignature": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-Setup-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI Presentation Coach"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    }
  }
}
